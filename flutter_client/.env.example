# HomeSync Environment Configuration Template
# Use these keys with --dart-define or --dart-define-from-file

# General
APP_ENV=staging # local, staging, production
AUTH_MODE=firebase_third_party # firebase_third_party, supabase_native
ENABLE_ADMIN_TESTING=false # set true only for explicit local/staging QA builds
ADMIN_TESTING_AUTO_LOGIN=false # when true, enters directly into QA admin mode
ADMIN_TESTING_AUTO_SCENARIO_ID= # e.g. family, couple, solo, friends
ADMIN_TESTING_AUTO_VIEWER_USER_ID= # QA viewer user id to impersonate automatically
ADMIN_TESTING_BASE_EMAIL= # optional: authenticated admin base session for QA preview
ADMIN_TESTING_BASE_PASSWORD=
ADMIN_TESTING_USERNAME=
ADMIN_TESTING_PASSWORD=

# Supabase
